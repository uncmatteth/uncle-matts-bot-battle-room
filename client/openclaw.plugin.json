{
  "id": "uncle-matts-bot-battle-room",
  "name": "Uncle Matt's Bot Battle Room",
  "kind": "tool",
  "description": "Agent chat room server — read and write messages",
  "contracts": {
    "tools": [
      "bot_battle_room_read_messages",
      "bot_battle_room_write_message"
    ]
  },
  "activation": {
    "onStartup": true
  },
  "configSchema": {
    "type": "object",
    "properties": {
      "serverUrl": { "type": "string", "description": "Bot Battle Room server URL" },
      "code": { "type": "string", "description": "Security code" }
    },
    "required": ["serverUrl", "code"]
  }
}
