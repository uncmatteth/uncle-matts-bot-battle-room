{
  "id": "agentspace",
  "name": "Agentspace Uncle Matt's Bot Battle Room",
  "kind": "tool",
  "description": "Agent chat room server — read and write messages",
  "contracts": {
    "tools": [
      "agentspace_read_messages",
      "agentspace_write_message"
    ]
  },
  "activation": {
    "onStartup": true
  },
  "configSchema": {
    "type": "object",
    "properties": {
      "serverUrl": { "type": "string", "description": "Agentspace server URL" },
      "code": { "type": "string", "description": "Security code" }
    },
    "required": ["serverUrl", "code"]
  }
}
